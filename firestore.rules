rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all security net: deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Predicate helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isSignedIn() || userId.startsWith('guest_local_');
      allow write: if isOwner(userId) || userId.startsWith('guest_local_');
    }

    // Tests Collection — only owner can read/write their own tests
    match /tests/{testId} {
      // Owner can always read their test
      allow read: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      // Group members can read a test if it is shared in a group they belong to
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/groups/$(request.query)/members/$(request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      // Questions Subcollection — readable by test owner
      match /questions/{questionId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/tests/$(testId)).data.createdBy == request.auth.uid;
        allow write: if isSignedIn() && get(/databases/$(database)/documents/tests/$(testId)).data.createdBy == request.auth.uid;
      }
    }

    // Independent Student Practices & Sessions Progression rules
    match /progress/{progressId} {
      allow read, write: if true;
    }

    // Study Group Workspace rules
    match /groups/{groupId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid) || (!isSignedIn() && resource.data.createdBy.startsWith('guest_local_'));

      // Nested Members hierarchy
      match /members/{memberId} {
        allow read: if true;
        allow write: if true;
      }

      // Shared Examinations Subcollection records (individual progress isolates to users)
      match /sharedTests/{testId} {
        allow read: if true;
        allow write: if true;
      }

      // Realtime Group Messages Subcollection
      match /messages/{messageId} {
        allow read: if true;
        allow create: if true;
        allow delete: if true;
      }
    }
  }
}
