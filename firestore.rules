rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all security net: deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Predicate helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isSignedIn() || userId.startsWith('guest_local_');
      allow write: if isOwner(userId) || userId.startsWith('guest_local_');
    }

    // Tests Collection
    match /tests/{testId} {
      // GET by ID — any signed-in user can read a specific test (needed for group sharing)
      allow get: if isSignedIn();
      // LIST/QUERY — only owner sees their own tests in queries (enforced also in code with where())
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /questions/{questionId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow write: if isSignedIn() && get(/databases/$(database)/documents/tests/$(testId)).data.createdBy == request.auth.uid;
      }
    }

    // Independent Student Practices & Sessions Progression rules
    match /progress/{progressId} {
      allow read, write: if true;
    }

    // Study Group Workspace rules
    match /groups/{groupId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid) || (!isSignedIn() && resource.data.createdBy.startsWith('guest_local_'));

      // Nested Members hierarchy
      match /members/{memberId} {
        allow read: if true;
        allow write: if true;
      }

      // Shared Examinations Subcollection records (individual progress isolates to users)
      match /sharedTests/{testId} {
        allow read: if true;
        allow write: if true;
      }

      // Realtime Group Messages Subcollection
      match /messages/{messageId} {
        allow read: if true;
        allow create: if true;
        allow delete: if true;
      }
    }
  }
}
